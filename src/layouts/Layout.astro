---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Vishvendra Pratap Singh Tomar — Backend Engineer specialising in distributed systems, LLM integrations, and AI tooling." />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script>
      const toggle = document.getElementById('theme-toggle');
      const stored = localStorage.getItem('theme');
      if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
      toggle?.addEventListener('click', () => {
        const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        document.documentElement.setAttribute('data-theme', isDark ? 'light' : 'dark');
        localStorage.setItem('theme', isDark ? 'light' : 'dark');
      });
    </script>
  </body>
</html>

<style is:global>
  /* ===== CSS Reset ===== */
  *, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  /* ===== Theme Variables ===== */
  :root {
    --bg: #ffffff;
    --bg-alt: #f7f7f7;
    --text: #1a1a1a;
    --text-muted: #555555;
    --accent: #222222;
    --border: #cccccc;
    --link: #1a0dab;
    --font-serif: Georgia, 'Times New Roman', Times, serif;
    --font-sans: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    --max-width: 900px;
  }

  [data-theme="dark"] {
    --bg: #1a1a2e;
    --bg-alt: #16213e;
    --text: #e0e0e0;
    --text-muted: #a0a0a0;
    --accent: #e0e0e0;
    --border: #444466;
    --link: #8ab4f8;
  }

  /* ===== Base ===== */
  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font-serif);
    font-size: 15px;
    line-height: 1.7;
    color: var(--text);
    background: var(--bg);
    -webkit-font-smoothing: antialiased;
  }

  a {
    color: var(--link);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  /* ===== Paper Container ===== */
  .paper {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 60px 40px;
  }

  /* ===== Header ===== */
  .paper-header {
    text-align: center;
    margin-bottom: 10px;
    position: relative;
  }

  .paper-title {
    font-family: var(--font-serif);
    font-size: 2.2rem;
    font-weight: 900;
    font-style: normal;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    line-height: 1.25;
    color: var(--accent);
  }

  .paper-subtitle {
    font-style: italic;
    font-size: 1.05rem;
    color: var(--text-muted);
    margin-top: 12px;
    line-height: 1.5;
  }

  .paper-meta {
    margin-top: 16px;
    font-size: 0.92rem;
    color: var(--text);
    line-height: 1.8;
  }

  .paper-meta a {
    color: var(--text);
  }

  .paper-meta a:hover {
    color: var(--link);
  }

  .separator {
    display: inline-block;
    margin: 0 8px;
  }

  /* ===== Theme Toggle ===== */
  .theme-toggle {
    position: absolute;
    top: 0;
    right: 0;
    background: none;
    border: 1px solid var(--border);
    border-radius: 50%;
    width: 38px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--text);
    transition: border-color 0.2s;
  }

  .theme-toggle:hover {
    border-color: var(--text);
  }

  /* Show sun in dark mode, moon in light mode */
  .icon-sun { display: none; }
  .icon-moon { display: block; }

  [data-theme="dark"] .icon-sun { display: block; }
  [data-theme="dark"] .icon-moon { display: none; }

  /* ===== Divider ===== */
  hr {
    border: none;
    border-top: 2px solid var(--accent);
    margin: 30px 0;
  }

  /* ===== Two Column Layout ===== */
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: start;
  }

  /* ===== Section Styles ===== */
  .section {
    margin-bottom: 32px;
  }

  .section-title {
    font-family: var(--font-sans);
    font-size: 1.35rem;
    font-weight: 700;
    margin-bottom: 14px;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .subsection-title {
    font-family: var(--font-sans);
    font-size: 1.05rem;
    font-weight: 700;
    margin-top: 20px;
    margin-bottom: 8px;
    color: var(--accent);
  }

  .section p {
    text-align: justify;
    text-indent: 2em;
    margin-bottom: 8px;
  }

  .section p.no-indent {
    text-indent: 0;
  }

  /* ===== Tech Stack Categories ===== */
  .stack-category {
    margin-bottom: 10px;
  }

  .stack-label {
    font-weight: 700;
    font-style: italic;
    display: block;
    margin-bottom: 2px;
  }

  .stack-items {
    margin-left: 2em;
    font-size: 0.93rem;
    color: var(--text-muted);
  }

  /* ===== Technologies Tag ===== */
  .technologies {
    font-style: italic;
    font-weight: 700;
    margin-top: 8px;
    font-size: 0.92rem;
  }

  .technologies span {
    font-weight: 400;
    font-style: italic;
    color: var(--text-muted);
  }

  /* ===== Bullet Points ===== */
  .bullet-list {
    list-style: none;
    padding: 0;
    margin-top: 6px;
  }

  .bullet-list li {
    padding-left: 1.2em;
    position: relative;
    margin-bottom: 4px;
    font-size: 0.93rem;
  }

  .bullet-list li::before {
    content: '\2022';
    position: absolute;
    left: 0;
  }

  /* ===== Research Interests ===== */
  .research-interests {
    text-indent: 2em;
    margin-bottom: 8px;
  }

  .research-interests em:first-child {
    font-weight: 600;
  }

  /* ===== Appendix ===== */
  .appendix {
    margin-bottom: 28px;
  }

  .appendix-title {
    font-family: var(--font-sans);
    font-size: 1.2rem;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--accent);
  }

  .experience-entry {
    margin-bottom: 6px;
    font-size: 0.94rem;
  }

  .experience-entry em {
    font-style: italic;
  }

  /* ===== Contact Box ===== */
  .contact-box {
    border: 1px solid var(--border);
    padding: 20px 28px;
    margin-top: 8px;
    border-radius: 2px;
    background: var(--bg-alt);
  }

  .contact-box p {
    margin-bottom: 10px;
    font-style: italic;
    text-indent: 0 !important;
    color: var(--text-muted);
  }

  .contact-item {
    margin-bottom: 4px;
    font-size: 0.94rem;
  }

  .contact-item strong {
    font-family: var(--font-sans);
    font-size: 0.88rem;
  }

  /* ===== Footer ===== */
  .footer {
    text-align: center;
    padding: 30px 0 10px;
    font-size: 0.82rem;
    color: var(--text-muted);
    border-top: 1px solid var(--border);
    margin-top: 20px;
  }

  /* ===== Responsive ===== */
  @media (max-width: 700px) {
    .paper {
      padding: 30px 20px;
    }

    .paper-title {
      font-size: 1.4rem;
    }

    .two-col {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .section-title {
      font-size: 1.15rem;
    }

    body {
      font-size: 14px;
    }

    .theme-toggle {
      position: absolute;
      top: 0;
      right: 0;
    }
  }

  /* ===== Print ===== */
  @media print {
    .theme-toggle { display: none; }
    body { font-size: 12px; }
    .paper { padding: 0; }
    hr { border-top-color: #000; }
  }
</style>
